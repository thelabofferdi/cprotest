## 📊 DASHBOARD BACKEND (Exemple)

```typescript
// dashboard/dashboard.service.ts
export class DashboardService {
  async getDashboard(userId: string, period: 'day' | 'week' | 'month') {
    const { startDate, endDate } = this.getPeriodDates(period);
    
    // 1. Chiffre d'affaires
    const recettes = await this.prisma.transaction.aggregate({
      where: {
        userId,
        type: 'RECETTE',
        date: { gte: startDate, lte: endDate },
      },
      _sum: { montant: true },
    });
    const ca = recettes._sum.montant || 0;
    
    // 2. Charges variables
    const chargesVar = await this.prisma.transaction.aggregate({
      where: {
        userId,
        type: 'DEPENSE',
        date: { gte: startDate, lte: endDate },
        categorie: { in: ['semences', 'carburant', 'transport', 'ingredients'] }, // etc.
      },
      _sum: { montant: true },
    });
    const cv = chargesVar._sum.montant || 0;
    
    // 3. Charges fixes
    const chargesFix = await this.prisma.transaction.aggregate({
      where: {
        userId,
        type: 'DEPENSE',
        date: { gte: startDate, lte: endDate },
        categorie: { in: ['loyer', 'taxes', 'salaires'] },
      },
      _sum: { montant: true },
    });
    const cf = chargesFix._sum.montant || 0;
    
    // 4. Amortissements
    const equipments = await this.prisma.equipment.findMany({
      where: { userId, isActive: true },
    });
    const amortTotal = equipments.reduce((sum, eq) => {
      const days = this.getDaysBetween(startDate, endDate);
      return sum + (eq.amortJournalier * days);
    }, 0);
    
    // 5. Calculs indicateurs
    const mcv = ca - cv;
    const rn = ca - cv - cf - amortTotal;
    const tauxMarge = ca > 0 ? (mcv / ca) * 100 : 0;
    const tauxProfit = ca > 0 ? (rn / ca) * 100 : 0;
    const sr = tauxMarge > 0 ? cf / (tauxMarge / 100) : 0;
    
    // 6. Trésorerie
    const tresorerie = await this.calculateTresorerie(userId);
    
    // 7. Alertes
    const alertes = [];
    if (cv + cf > ca * 0.80) alertes.push('depenses_elevees');
    if (ca < sr) alertes.push('sr_non_atteint');
    if (rn < 0) alertes.push('resultat_negatif');
    
    return {
      periode: { startDate, endDate, type: period },
      indicateurs: {
        ca,
        rn,
        tauxProfit,
        tresorerie,
        ratioCharges: ca > 0 ? ((cv + cf) / ca) * 100 : 0,
        seuilRentabilite: sr,
        tauxMarge,
        mcv,
      },
      alertes,
    };
  }
}
```

