# Database
DATABASE_URL="postgresql://cpro:password@localhost:5432/cpro?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-super-secret-refresh-key"
JWT_REFRESH_EXPIRES_IN="7d"

# Application
NODE_ENV="development"
PORT=3000
API_PREFIX="api/v1"

# Email (Resend)
RESEND_API_KEY="re_xxxxx"
FROM_EMAIL="C'PRO <noreply@cpro.app>"

# Storage (Cloudflare R2 - S3 compatible)
R2_ENDPOINT="https://xxxxx.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="xxxxx"
R2_SECRET_ACCESS_KEY="xxxxx"
R2_BUCKET_NAME="cpro-documents"
R2_PUBLIC_URL="https://files.cpro.app"

# Firebase Cloud Messaging
FCM_PROJECT_ID="cpro-app"
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxxx\n-----END PRIVATE KEY-----\n"
FCM_CLIENT_EMAIL="firebase-adminsdk-xxxxx@cpro-app.iam.gserviceaccount.com"

# Redis (optionnel - pour cache et queue)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# Sentry (monitoring - optionnel)
SENTRY_DSN=""

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
